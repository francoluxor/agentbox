# AgentBox host relay image.
#
# Tiny HTTP server that boxes POST events / RPCs to. Lives on the docker
# user-defined network `agentbox-net` alongside boxes; the host CLI talks to
# it via `docker exec`. Single CJS bin baked in — same packaging pattern as
# the agentbox-ctl bin inside the box image.
#
# Build context is the monorepo root so the COPY below resolves.
FROM node:22-alpine

WORKDIR /app

COPY packages/relay/dist/bin.cjs /usr/local/bin/agentbox-relay
RUN chmod +x /usr/local/bin/agentbox-relay

EXPOSE 8787

CMD ["node", "/usr/local/bin/agentbox-relay", "serve", "--port", "8787"]
