{
  "name": "agentbox",
  "version": "0.0.0",
  "description": "Launch Claude Code, Codex, and other coding agents in isolated sandboxes",
  "license": "MIT",
  "type": "module",
  "bin": {
    "agentbox": "./dist/index.js"
  },
  "files": [
    "dist",
    "share"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "lint": "eslint src test",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist .turbo"
  },
  "dependencies": {
    "@agentbox/config": "workspace:*",
    "@agentbox/core": "workspace:*",
    "@agentbox/ctl": "workspace:*",
    "@agentbox/sandbox-docker": "workspace:*",
    "@clack/prompts": "^0.9.0",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.1",
    "tsup": "^8.3.5",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
